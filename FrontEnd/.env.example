# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/tunegocio"

# NextAuth - genera un secret con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Modo demo temporal (deshabilita auth y usa datos mock)
DEMO_MODE="true"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."

# URL pública de la app (para generar links de landing pages)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
